shader_parameter/color_threshold_1 = 0.250000011875
shader_parameter/color_2 = Color(1, 1, 1, 1)
shader_parameter/color_replace_2 = Color(0, 0, 0, 1)
shader_parameter/color_threshold_2 = 0.01
shader_parameter/color_3 = Color(1, 1, 1, 1)
shader_parameter/color_replace_3 = Color(0, 0, 0, 1)
shader_parameter/color_threshold_3 = 0.01

